# ── Secrets & environment (NEVER commit these) ────────────────────────────────
.env
.env.*
.env.txt
.env.local
.env.*.local
*.env
secrets.json
secrets.js
credentials.json

# ── Capacitor (local only — not needed on Cloudflare) ────────────────────────
capacitor.config.json

# ── Node — package.json, package-lock.json and wrangler.toml ARE committed ────
